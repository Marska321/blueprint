{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A hardware project generated by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "prompt": { "type": "string" },
        "components": { "type": "array" },
        "wiring": { "type": "object" },
        "instructions": { "type": "string" },
        "createdAt": { "type": "number" },
        "totalCostZAR": { "type": "number" }
      },
      "required": ["id", "userId", "name", "description", "prompt", "components", "wiring", "instructions", "createdAt", "totalCostZAR"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of user hardware projects."
    }
  }
}
